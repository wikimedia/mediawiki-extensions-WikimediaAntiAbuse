{
	"name": "WikimediaAntiAbuse",
	"author": [
		"Kosta Harlan",
		"Dreamy Jazz"
	],
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:WikimediaAntiAbuse",
	"descriptionmsg": "wikimediaantiabuse-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.47.0"
	},
	"MessagesDirs": {
		"WikimediaAntiAbuse": [
			"i18n"
		]
	},
	"config": {
		"WikimediaAntiAbuseEnablePersonalInfoTag": {
			"value": false,
			"description": "Enables the mw-private-personal-info tag."
		},
		"WikimediaAntiAbuseCoPEModelConfig": {
			"value": {
				"url": "",
				"host": "",
				"timeout": ""
			},
			"description": "Configuration for the CoPE model used for content policy evaluation. Needs to be filled out with the appropriate URL and host. The timeout is optional and when non-empty will be used as the timeout for requests to the CoPE model."
		},
		"WikimediaAntiAbuseDeveloperMode": {
			"value": false,
			"description": "If developer mode is enabled. This should be set to false in production. Developer mode can affect whether e.g. SSL certification validation is enabled in HTTP requests"
		}
	},
	"HookHandlers": {
		"ChangeTagsHandler": {
			"class": "MediaWiki\\Extension\\WikimediaAntiAbuse\\Hooks\\Handlers\\ChangeTagsHandler",
			"services": [
				"MainConfig"
			]
		}
	},
	"Hooks": {
		"ChangeTagsListActive": "ChangeTagsHandler",
		"ListDefinedTags": "ChangeTagsHandler",
		"ListRestrictedTags": "ChangeTagsHandler"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\WikimediaAntiAbuse\\": "includes/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\WikimediaAntiAbuse\\Tests\\": "tests/"
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"manifest_version": 2
}
